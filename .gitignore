# =============================================================================
# .gitignore — auth-service Lambda project
# =============================================================================

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
.build/
dist/
*.zip
*.egg-info/
*.egg

# ---------------------------------------------------------------------------
# Python bytecode & caches
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/
.python-version

# ---------------------------------------------------------------------------
# Secrets & environment files — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.*
*.env
secrets.json
secrets.yaml
secrets.toml
db-secret.json
local-env.json
samconfig.toml       # Contains deployment params that may include secrets

# ---------------------------------------------------------------------------
# AWS / SAM
# ---------------------------------------------------------------------------
.aws-sam/
samconfig.toml
packaged.yaml

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ---------------------------------------------------------------------------
# Windows
# ---------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Linux
# ---------------------------------------------------------------------------
*~
.fuse_hidden*
.nfs*

# ---------------------------------------------------------------------------
# IDE / editor & local tooling
# ---------------------------------------------------------------------------
.idea/
.vscode/
.claude/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
